# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Local services
DATABASE_URL=postgresql://automation:automation@localhost:5432/automation
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Local dashboard/scraping
SCRAPE_DELAY_SECONDS=2.0
MAX_RESULTS_PER_QUERY=50
HEADLESS_BROWSER=true

# Google Maps / lead discovery
GOOGLE_MAPS_API_KEY=
OUTSCRAPER_API_KEY=

# AI providers, currently optional
AI_PROVIDER=openai
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
GEMINI_API_KEY=

# CRM / notifications, currently optional
NOTION_TOKEN=
NOTION_DATABASE_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional deployment and repository integrations
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_ORG=
GITHUB_PAGES_DOMAIN=
RESEND_API_KEY=
VERCEL_TOKEN=
VERCEL_ORG_ID=
NETLIFY_TOKEN=
NETLIFY_SITE_ID=

# Evolution API / n8n deployment
EVOLUTION_API_KEY=
EVOLUTION_POSTGRES_PASSWORD=
EVOLUTION_SERVER_URL=http://localhost:8080
EVOLUTION_SESSION_PHONE_VERSION=2.3000.10216511034
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PUBLIC_URL=http://localhost:5678/
N8N_WEBHOOK_URL=http://n8n:5678/webhook/whatsapp-buffer
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_SECURE_COOKIE=false

# Message buffer service
EVOLUTION_WEBHOOK_URL=http://message-buffer:8081/webhook/evolution
MESSAGE_BUFFER_SECONDS=8
MESSAGE_BUFFER_MAX_MESSAGES=20
MESSAGE_BUFFER_MAX_AGE_SECONDS=120
MESSAGE_BUFFER_DEDUP_TTL_SECONDS=86400
MESSAGE_BUFFER_POLL_SECONDS=1.0
N8N_REQUEST_TIMEOUT_SECONDS=10.0
TRANSCRIPTION_PROVIDER=disabled
WHISPER_API_KEY=
WHISPER_API_URL=https://api.openai.com/v1/audio/transcriptions
AUDIO_DOWNLOAD_TIMEOUT_SECONDS=15
MAX_AUDIO_SIZE_MB=10

# WhatsApp/Twilio placeholders, not used for outbound automation yet
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
MY_WHATSAPP_NUMBER=

# Tracking placeholders
TRACKING_DOMAIN=
TRACKING_SECRET_KEY=
