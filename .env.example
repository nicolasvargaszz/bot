# Application
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Local services
DATABASE_URL=postgresql://automation:automation@localhost:5432/automation
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Local dashboard/scraping
SCRAPE_DELAY_SECONDS=2.0
MAX_RESULTS_PER_QUERY=50
HEADLESS_BROWSER=true

# Google Maps / lead discovery
GOOGLE_MAPS_API_KEY=
OUTSCRAPER_API_KEY=

# AI providers, currently optional
AI_PROVIDER=openai
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
GEMINI_API_KEY=

# CRM / notifications, currently optional
NOTION_TOKEN=
NOTION_DATABASE_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional deployment and repository integrations
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_ORG=
GITHUB_PAGES_DOMAIN=
RESEND_API_KEY=
VERCEL_TOKEN=
VERCEL_ORG_ID=
NETLIFY_TOKEN=
NETLIFY_SITE_ID=

# Evolution API / n8n deployment
EVOLUTION_API_KEY=
EVOLUTION_POSTGRES_PASSWORD=
EVOLUTION_SERVER_URL=http://localhost:8080
EVOLUTION_SESSION_PHONE_VERSION=2.3000.10216511034
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_PUBLIC_URL=http://localhost:5678/
N8N_WEBHOOK_URL=http://localhost:5678/webhook/campana
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=
N8N_SECURE_COOKIE=false

# WhatsApp/Twilio placeholders, not used for outbound automation yet
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=
MY_WHATSAPP_NUMBER=

# Tracking placeholders
TRACKING_DOMAIN=
TRACKING_SECRET_KEY=
